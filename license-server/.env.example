# ── Required ─────────────────────────────────────────────────────────────────
SCHEDULA_ADMIN_KEY=change-me-to-something-secret

# ── Stripe (optional — needed for online checkout) ────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products + prices in the Stripe Dashboard, then paste the price IDs:
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_INST_MONTHLY=price_...
STRIPE_PRICE_INST_ANNUAL=price_...

# Landing page URL used in redirect / email links
APP_URL=https://schedula.app

# ── Paddle (optional — enables Paddle checkout as alternative to Stripe) ──────
# Get these from https://vendors.paddle.com/authentication
PADDLE_API_KEY=pdl_live_...
PADDLE_WEBHOOK_SECRET=pdlws_...

# Create products + prices in Paddle Dashboard, then paste the price IDs:
PADDLE_PRICE_PRO_MONTHLY=pri_...
PADDLE_PRICE_PRO_ANNUAL=pri_...
PADDLE_PRICE_INST_MONTHLY=pri_...
PADDLE_PRICE_INST_ANNUAL=pri_...

# Client-side token for Paddle.js (public — safe to embed in landing page)
PADDLE_CLIENT_TOKEN=live_...

# ── Sales notifications (optional — for invoice/PO requests) ─────────────────
# Address that receives "new invoice request" emails
SALES_EMAIL=sales@schedula.app
# Slack incoming webhook URL (leave empty to disable)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── SMTP email (optional — needed to deliver license keys by email) ───────────
# Works with any SMTP provider: Gmail, SendGrid SMTP relay, Postmark, etc.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG....
SMTP_FROM=noreply@schedula.app
